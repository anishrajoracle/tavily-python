# Tavily Python SDK / Oracle demo environment template
#
# Copy this file to `.env` and fill in real values:
#
#   cp .env.example .env
#
# Do not commit `.env`. It contains secrets and is ignored by git.


# -----------------------------------------------------------------------------
# Tavily
# -----------------------------------------------------------------------------

TAVILY_API_KEY=tvly-your-api-key

# Optional: Tavily project/keyless mode support.
# TAVILY_PROJECT=your-project-id

# Optional Tavily search default used by notebooks/demo helpers.
# Common values: basic, advanced
TAVILY_SEARCH_DEPTH=basic


# -----------------------------------------------------------------------------
# Oracle Database
# -----------------------------------------------------------------------------

ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_DSN=localhost:1521/FREEPDB1

# Table and column names used by the Oracle vector/cache examples.
ORACLE_VECTOR_TABLE=TAVILY_DOCUMENTS
ORACLE_CONTENT_FIELD=CONTENT
ORACLE_EMBEDDINGS_FIELD=EMBEDDINGS
ORACLE_CACHE_TIMESTAMP_FIELD=ADDED_AT

# Oracle vector index settings.
ORACLE_VECTOR_INDEX_NAME=TAVILY_DOCS_VEC_IDX
ORACLE_VECTOR_DIMENSION=1024
ORACLE_VECTOR_INDEX_TYPE=HNSW
ORACLE_VECTOR_INDEX_DISTANCE=COSINE

# Optional: set to 1 only when you intentionally want the notebook to run
# live vector-index creation in an environment with enough Oracle vector memory.
ORACLE_RUN_VECTOR_INDEX_DEMO=0


# -----------------------------------------------------------------------------
# Oracle Cache / Memory Defaults
# -----------------------------------------------------------------------------

# Freshness cache time-to-live in seconds.
ORACLE_CACHE_TTL_SECONDS=3600

# Local result score thresholds.
# Use low/negative values for demos where you want local hits to show easily.
ORACLE_CACHE_SCORE_THRESHOLD=-1.0
ORACLE_MEMORY_SCORE_THRESHOLD=-1.0

# Number of durable-memory candidates inspected in cache_then_memory mode.
ORACLE_MEMORY_MAX_RESULTS=5

# Optional semantic deduplication threshold.
# Leave blank to disable, or use a value like 0.95.
ORACLE_DEDUP_SIMILARITY_THRESHOLD=

# Optional persistence controls.
# Leave blank to persist all Tavily results allowed by max_foreign.
ORACLE_MAX_PERSISTED_FOREIGN=
ORACLE_PERSIST_SCORE_THRESHOLD=

# Optional upsert key.
# Supported values: source_url, content_hash
# Leave blank to insert new rows normally.
ORACLE_UPSERT_KEY=

# Optional automatic cleanup for expired cache-only rows.
ORACLE_AUTO_CLEANUP_CACHE=0
ORACLE_CACHE_CLEANUP_INTERVAL_SECONDS=3600


# -----------------------------------------------------------------------------
# CLI Demo Aliases
# -----------------------------------------------------------------------------

# The standalone CLI demo accepts these older/simple names too.
ORACLE_TABLE=TAVILY_DOCUMENTS
ORACLE_RETRIEVAL_MODE=freshness_cache
CACHE_TTL_SECONDS=3600
CACHE_SCORE_THRESHOLD=0.75
MEMORY_SCORE_THRESHOLD=0.65
MEMORY_MAX_RESULTS=5
PERSISTENCE_DEPTH=cache_only


# -----------------------------------------------------------------------------
# MongoDB Examples
# -----------------------------------------------------------------------------

# Demo app / SDK convenience connection parameters.
# MongoDB currently supports hybrid_search only in the demo app.
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/
MONGO_DATABASE=your_database
MONGO_COLLECTION=your_collection
MONGO_INDEX=your_vector_search_index

# Optional MongoDB field names. Keep these aligned with your documents and
# Atlas Vector Search index definition.
MONGO_CONTENT_FIELD=content
MONGO_EMBEDDINGS_FIELD=embeddings

# Backward-compatible aliases used by some older examples/scripts.
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/
MONGODB_DATABASE=your_database
MONGODB_COLLECTION=your_collection
MONGODB_VECTOR_INDEX=your_vector_search_index


# -----------------------------------------------------------------------------
# Optional Provider Keys For Examples
# -----------------------------------------------------------------------------

# Cohere is used by the default hybrid RAG embedding/reranking helpers when
# custom embedding/ranking functions are not supplied.
CO_API_KEY=your-cohere-api-key

# Some general examples use OpenAI directly.
OPENAI_API_KEY=your-openai-api-key


# -----------------------------------------------------------------------------
# Proxy Settings
# -----------------------------------------------------------------------------

# Set to 1 only if Tavily requests should use the proxy variables below.
TAVILY_USE_ENV_PROXY=0

# Optional standard proxy variables.
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

# Optional Tavily-specific proxy variables used by TavilyClient.
TAVILY_HTTPS_PROXY=
TAVILY_HTTP_PROXY=


# -----------------------------------------------------------------------------
# Local Demo App
# -----------------------------------------------------------------------------

# Port used by ../tavily-demo-app/app.py
TAVILY_DEMO_PORT=8765

ORACLE_ENABLE_NATIVE_HYBRID_SEARCH=0
